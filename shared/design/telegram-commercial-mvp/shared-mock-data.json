{
  "meta": {
    "name": "telegram-commercial-mvp-mock-data",
    "version": "1.1.0",
    "description": "Mock data, navigation routing, and behavioral specs for the Telegram Commercial MVP. Aligned with CJMP implementation through slice 6."
  },
  "startup": {
    "defaultAuthenticatedDestination": "home-shell",
    "restoreBehavior": {
      "validSessionDestination": "home-shell",
      "invalidSessionDestination": "login"
    }
  },
  "login": {
    "brandTitle": "Telegram",
    "countryValue": "China",
    "phonePrefix": "+86",
    "verificationCodeExample": "12345"
  },
  "homeShell": {
    "defaultTab": "chats",
    "layout": {
      "appBarStyle": "title-subtitle with trailing utility actions",
      "contentAreaStyle": "full-height grouped list inside padded shell",
      "tabBarStyle": "three pill buttons"
    },
    "tabs": [
      {
        "id": "chats",
        "labelKey": "homeShell.tabs.chats",
        "iconId": "chat-bubble",
        "implementedInSlice": 4
      },
      {
        "id": "contacts",
        "labelKey": "homeShell.tabs.contacts",
        "iconId": "contacts",
        "implementedInSlice": 4,
        "placeholderDestination": false,
        "surfaceStyle": "grouped-list"
      },
      {
        "id": "settings",
        "labelKey": "homeShell.tabs.settings",
        "iconId": "settings",
        "implementedInSlice": 4,
        "placeholderDestination": false,
        "surfaceStyle": "grouped-list"
      }
    ],
    "tabContent": {
      "chats": {
        "title": "Telegram",
        "subtitle": "Shared seed conversations with pinned, muted, and unread cues.",
        "showsStateFilters": true
      },
      "contacts": {
        "title": "Contacts",
        "subtitle": "People, invites, and synced contacts."
      },
      "settings": {
        "title": "Settings",
        "subtitle": "Account and app preferences."
      }
    },
    "implementationOnlyActions": {
      "chats": [
        "edit",
        "find"
      ],
      "contacts": [
        "add"
      ]
    }
  },
  "chatListStates": {
    "available": [
      "populated",
      "loading",
      "empty",
      "error"
    ]
  },
